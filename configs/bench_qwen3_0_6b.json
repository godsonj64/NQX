{
  "model": "qwen3-0.6b",
  "variants": [
    "baseline",
    "nqx-balanced"
  ],
  "output_dir": "benchmark-results",
  "checkpoint_dir": "outputs/bench-checkpoints",
  "device": "cuda:0",
  "dtype": "bfloat16",
  "backend": "torch",
  "seed": 0,
  "trust_remote_code": false,
  "resume": true,
  "quantize_if_missing": true,
  "hash_checkpoint": false,
  "dataset": "wikitext2",
  "dataset_split": "test",
  "sequence_length": 1024,
  "stride": 512,
  "max_eval_tokens": 16384,
  "fidelity_samples": 4,
  "fidelity_length": 256,
  "teacher_topk": 128,
  "prefill_lengths": [
    128,
    512,
    1024
  ],
  "generation_max_new_tokens": 64,
  "warmup_runs": 2,
  "repeat_runs": 5,
  "bits": 1.0,
  "num_calib_samples": 128,
  "calibration_sequence_length": 2048,
  "calib_dataset": "wikitext2",
  "calib_shrinkage": 0.2,
  "calib_strategy": "online",
  "tune_nonfact": true,
  "nonfact_epochs": 8,
  "admm_outer_iters": 400,
  "admm_inner_iters": 5,
  "admm_reg": 0.03,
  "admm_penalty_scheduler": "linear",
  "nqx_scale_iters": 4,
  "nqx_scale_ridge": 0.000001,
  "nqx_chunk_rows": 256,
  "tune_fact": true,
  "fact_epochs": 8,
  "tune_model": true,
  "model_kd_epochs": 8,
  "nqx_kd_topk": 128,
  "nqx_kd_temperature": 1.0
}

